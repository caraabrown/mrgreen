<script>

// ── PASSWORD GATE ─────────────────────────────────────────────────────────────
const PW_KEY = 'wts_admin_pw';
const SESSION_KEY = 'wts_admin_session';

function initGate() {
  const stored = localStorage.getItem(PW_KEY);
  const session = sessionStorage.getItem(SESSION_KEY);
  if (session === '1') { unlock(); return; }
  document.getElementById('pwGate').classList.remove('hidden');
  if (!stored) {
    document.getElementById('pwSetup').style.display = 'block';
  } else {
    document.getElementById('pwLogin').style.display = 'block';
    setTimeout(() => document.getElementById('pwEntry').focus(), 100);
  }
}

function setPassword() {
  const pw = document.getElementById('pwNew').value;
  const confirm = document.getElementById('pwConfirm').value;
  const err = document.getElementById('pwSetupError');
  if (!pw || pw.length < 6) { err.textContent = 'Password must be at least 6 characters.'; return; }
  if (pw !== confirm) { err.textContent = 'Passwords do not match.'; return; }
  localStorage.setItem(PW_KEY, btoa(pw));
  sessionStorage.setItem(SESSION_KEY, '1');
  unlock();
}

function checkPassword() {
  const entered = document.getElementById('pwEntry').value;
  const stored = localStorage.getItem(PW_KEY);
  const err = document.getElementById('pwLoginError');
  if (!entered) { err.textContent = 'Please enter your password.'; return; }
  if (btoa(entered) !== stored) {
    err.textContent = 'Incorrect password. Try again.';
    document.getElementById('pwEntry').value = '';
    document.getElementById('pwEntry').focus();
    return;
  }
  sessionStorage.setItem(SESSION_KEY, '1');
  unlock();
}

function unlock() {
  document.getElementById('pwGate').classList.add('hidden');
}

function logout() {
  sessionStorage.removeItem(SESSION_KEY);
  location.reload();
}

function changePassword() {
  const current = document.getElementById('pwCurrent').value;
  const newPw = document.getElementById('pwNewChange').value;
  const confirm = document.getElementById('pwConfirmChange').value;
  const err = document.getElementById('pwChangeError');
  const stored = localStorage.getItem(PW_KEY);
  if (btoa(current) !== stored) { err.textContent = 'Current password is incorrect.'; return; }
  if (!newPw || newPw.length < 6) { err.textContent = 'New password must be at least 6 characters.'; return; }
  if (newPw !== confirm) { err.textContent = 'New passwords do not match.'; return; }
  localStorage.setItem(PW_KEY, btoa(newPw));
  err.style.color = 'var(--green-lt)';
  err.textContent = 'Password updated successfully ✓';
  ['pwCurrent','pwNewChange','pwConfirmChange'].forEach(id => document.getElementById(id).value = '');
  setTimeout(() => { err.textContent = ''; err.style.color = 'var(--crimson)'; }, 3000);
}

initGate();

// ── BOOKS DATA (pre-seeded from Mr. Green's list) ────────────────────────────
const DEFAULT_BOOKS = [
  {title:"The Spook Who Sat by the Door",author:"Sam Greenlee",genre:"fiction",note:""},
  {title:"The Autobiography of Malcolm X",author:"Alex Haley",genre:"biography",note:""},
  {title:"Miseducation of the Negro",author:"Carter G. Woodson",genre:"history",note:""},
  {title:"Invisible Man",author:"Ralph Ellison",genre:"fiction",note:""},
  {title:"Race Matters",author:"Cornel West",genre:"politics",note:""},
  {title:"Up From Slavery",author:"Booker T. Washington",genre:"biography",note:""},
  {title:"Malcolm X: A Life of Reinvention",author:"Manning Marable",genre:"biography",note:""},
  {title:"The Poisonwood Bible",author:"Barbara Kingsolver",genre:"fiction",note:""},
  {title:"Wealth of Nations",author:"Adam Smith",genre:"politics",note:""},
  {title:"The Color of Law",author:"Richard Rothstein",genre:"history",note:""},
  {title:"The New Jim Crow",author:"Michelle Alexander",genre:"history",note:""},
  {title:"Caste",author:"Isabel Wilkerson",genre:"history",note:""},
];

// ── STATE ────────────────────────────────────────────────────────────────────
let state = {
  questions: JSON.parse(localStorage.getItem('dash_questions') || '[]'),
  books: JSON.parse(localStorage.getItem('dash_books') || JSON.stringify(DEFAULT_BOOKS)),
  photos: JSON.parse(localStorage.getItem('dash_photos') || '[]'),
  media: JSON.parse(localStorage.getItem('dash_media') || '[]'),
  timeline: JSON.parse(localStorage.getItem('dash_timeline') || '[]'),
};

function saveState() {
  Object.keys(state).forEach(k => localStorage.setItem('dash_'+k, JSON.stringify(state[k])));
}

function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('visible');
  setTimeout(() => el.classList.remove('visible'), 2500);
}

function saveAll() { saveState(); toast('Changes saved ✓'); }

// ── PANEL NAVIGATION ──────────────────────────────────────────────────────────
const panelMeta = {
  questions: ['Questions','Review, answer, and assign books to submitted questions'],
  messages:  ['Private Messages','Messages sent directly to you through the profile form'],
  profiles:  ['Profile Approvals','Approve or decline submitted profiles for the Black People page'],
  stories:   ['Light Bulb Stories','Approve submissions and feature them in the rotating homepage section'],
  books:     ['Book Library','Manage your reading list and add new titles'],
  photos:    ['Photo Gallery','Upload photos to the About Mr. Green page'],
  media:     ['Media Coverage','Add press links to the About Mr. Green page'],
  timeline:   ['Timeline','Add entries to the life timeline on About Mr. Green'],
  donations:  ['Donations','Track contributions, view totals, and manage giving history'],
  settings:   ['Settings','Change your dashboard password and manage access'],
};
function showPanel(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  event.currentTarget.classList.add('active');
  document.getElementById('topbarTitle').textContent = panelMeta[id][0];
  document.getElementById('topbarSub').textContent = panelMeta[id][1];
  if (id === 'questions') renderQuestions();
  if (id === 'messages')  renderPrivateMessages();
  if (id === 'profiles')  renderProfiles();
  if (id === 'stories')   renderStories();
  if (id === 'books') renderBooks();
  if (id === 'photos') renderPhotoPending();
  if (id === 'media') renderMediaPending();
  if (id === 'donations') renderDonations();
  if (id === 'settings') {}  // static panel
}

// ── QUESTIONS ────────────────────────────────────────────────────────────────
function renderQuestions() {
  const qs = state.questions;
  document.getElementById('statTotal').textContent = qs.length;
  document.getElementById('statUnanswered').textContent = qs.filter(q=>!q.answer).length;
  document.getElementById('statAnswered').textContent = qs.filter(q=>q.answer).length;
  document.getElementById('statBooks').textContent = state.books.length;
  document.getElementById('qBadge').textContent = qs.filter(q=>!q.answer).length;
  document.getElementById('msgBadge').textContent = 2; // demo

  const list = document.getElementById('questionsList');
  if (!qs.length) {
    list.innerHTML = `<div style="font-family:var(--font-body);font-size:0.88rem;color:var(--muted);font-style:italic;padding:2rem 0;">No questions submitted yet. Click "Add Demo Question" to test the flow.</div>`;
    return;
  }
  list.innerHTML = qs.map((q,i) => `
    <div class="q-item ${q.answer ? 'answered' : 'unanswered'}" onclick="toggleEditor(${i})">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;">
        <span class="tag ${q.answer ? 'tag-answered' : 'tag-new'}">${q.answer ? 'Answered' : 'Unanswered'}</span>
        <span style="font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.1em;color:var(--faint);">${q.date}</span>
      </div>
      <div class="q-text">${q.question}</div>
      ${q.answer ? `<div style="font-family:var(--font-body);font-size:0.75rem;color:var(--green-lt);margin-top:0.4rem;">✓ Answered · ${q.book ? 'Book: '+q.book : 'No book assigned'}</div>` : ''}
    </div>
    <div class="answer-editor ${q._open ? 'open' : ''}" id="editor-${i}">
      <label class="field-label">Your Answer</label>
      <textarea class="field-input" id="ans-${i}" style="min-height:140px;" placeholder="Type your answer here — you can use plain language, Mr. Green. This will be formatted and published.">${q.answer||''}</textarea>
      
      <label class="field-label">Assign a Book from Your Library</label>
      <select class="field-input" id="book-${i}">
        <option value="">— No book for this question —</option>
        ${state.books.map(b=>`<option value="${b.title}" ${q.book===b.title?'selected':''}>${b.title} · ${b.author}</option>`).join('')}
      </select>

      <label class="field-label">Or type in a new book title</label>
      <div style="display:flex;gap:0.5rem;">
        <input class="field-input" id="newbook-${i}" type="text" placeholder="New book title..." style="flex:1;"/>
        <button class="save-btn" onclick="addBookFromQuestion(${i})" style="white-space:nowrap;padding:0.75rem 1rem;">Add Book</button>
      </div>

      <div style="display:flex;gap:0.75rem;margin-top:1.25rem;">
        <button class="save-btn green" onclick="saveAnswer(${i})">Publish Answer →</button>
        <button class="save-btn" style="background:var(--faint);" onclick="toggleEditor(${i})">Cancel</button>
      </div>
    </div>
  `).join('');
}

function toggleEditor(i) {
  state.questions[i]._open = !state.questions[i]._open;
  renderQuestions();
}

function saveAnswer(i) {
  const ans = document.getElementById('ans-'+i).value.trim();
  const book = document.getElementById('book-'+i).value;
  if (!ans) { toast('Please write an answer first.'); return; }
  state.questions[i].answer = ans;
  state.questions[i].book = book || null;
  state.questions[i]._open = false;
  saveState();
  renderQuestions();
  toast('Answer published ✓');
}

function addBookFromQuestion(i) {
  const title = document.getElementById('newbook-'+i).value.trim();
  if (!title) return;
  state.books.push({title, author:'', genre:'other', note:''});
  saveState();
  renderQuestions();
  toast('Book added to library ✓');
}

function addDemoQuestion() {
  const demos = [
    "Why do Black communities have less generational wealth?",
    "Were the Black Panthers actually violent?",
    "What is systemic racism — is it real?",
    "Why is slavery still relevant today?",
    "Did the Civil Rights Act fix inequality?",
  ];
  const q = demos[state.questions.length % demos.length];
  state.questions.push({question:q, answer:null, book:null, date:new Date().toLocaleDateString(), _open:false});
  saveState();
  renderQuestions();
  toast('Demo question added ✓');
}

// ── BOOKS ────────────────────────────────────────────────────────────────────
function renderBooks() {
  const lib = document.getElementById('bookLibrary');
  lib.innerHTML = state.books.map((b,i) => `
    <div class="dash-card" style="padding:0.85rem 1rem;margin-bottom:0.5rem;display:flex;justify-content:space-between;align-items:center;">
      <div>
        <div style="font-family:var(--font-head);font-size:0.82rem;color:var(--text);margin-bottom:0.2rem;">${b.title}</div>
        <div style="font-family:var(--font-body);font-size:0.72rem;color:var(--muted);">${b.author} · <span style="color:var(--gold);">${b.genre}</span></div>
      </div>
      <button onclick="removeBook(${i})" style="background:none;border:none;cursor:pointer;color:var(--faint);font-size:1rem;padding:0.25rem 0.5rem;" title="Remove">×</button>
    </div>
  `).join('');
  document.getElementById('statBooks').textContent = state.books.length;
}

function addBook() {
  const title = document.getElementById('newBookTitle').value.trim();
  const author = document.getElementById('newBookAuthor').value.trim();
  const genre = document.getElementById('newBookGenre').value;
  const note = document.getElementById('newBookNote').value.trim();
  if (!title) { toast('Please enter a book title.'); return; }
  state.books.push({title,author,genre,note});
  saveState();
  renderBooks();
  document.getElementById('newBookTitle').value='';
  document.getElementById('newBookAuthor').value='';
  document.getElementById('newBookNote').value='';
  toast('Book added to library ✓');
}

function removeBook(i) {
  if (!confirm('Remove "'+state.books[i].title+'" from library?')) return;
  state.books.splice(i,1);
  saveState();
  renderBooks();
  toast('Book removed ✓');
}

// ── PHOTOS ───────────────────────────────────────────────────────────────────
function previewPhoto(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('photoPreviewImg').src = e.target.result;
    document.getElementById('photoPreview').style.display = 'block';
  };
  reader.readAsDataURL(file);
}

function addPhoto() {
  const label = document.getElementById('photoLabel').value.trim();
  const caption = document.getElementById('photoCaption').value.trim();
  const file = document.getElementById('photoUpload').files[0];
  if (!label || !caption) { toast('Please add a caption and description.'); return; }
  const entry = {label, caption, filename: file ? file.name : 'pending-upload', date: new Date().toLocaleDateString()};
  state.photos.push(entry);
  saveState();
  renderPhotoPending();
  document.getElementById('photoLabel').value='';
  document.getElementById('photoCaption').value='';
  document.getElementById('photoPreview').style.display='none';
  toast('Photo added — upload file to GitHub to publish ✓');
}

function renderPhotoPending() {
  const el = document.getElementById('photoPending');
  if (!state.photos.length) {
    el.innerHTML = '<div style="font-family:var(--font-body);font-size:0.82rem;color:var(--muted);font-style:italic;">No photos added yet.</div>';
    return;
  }
  el.innerHTML = state.photos.map((p,i) => `
    <div class="dash-card" style="padding:0.85rem 1rem;margin-bottom:0.5rem;">
      <div style="font-family:var(--font-head);font-size:0.78rem;color:var(--gold);margin-bottom:0.2rem;">${p.label}</div>
      <div style="font-family:var(--font-body);font-size:0.75rem;color:var(--text);margin-bottom:0.25rem;">${p.caption}</div>
      <div style="font-family:var(--font-body);font-size:0.65rem;color:var(--faint);">File: ${p.filename} · Added ${p.date}</div>
    </div>
  `).join('');
}

// ── MEDIA ────────────────────────────────────────────────────────────────────
function addMedia() {
  const outlet = document.getElementById('mediaOutlet').value.trim();
  const headline = document.getElementById('mediaHeadline').value.trim();
  const url = document.getElementById('mediaUrl').value.trim();
  const thumbnail = document.getElementById('mediaThumbnail').value.trim();
  const color = document.getElementById('mediaColor').value;
  if (!outlet || !headline || !url) { toast('Please fill in outlet, headline, and URL.'); return; }
  state.media.push({outlet,headline,url,thumbnail,color,date:new Date().toLocaleDateString()});
  saveState();
  renderMediaPending();
  ['mediaOutlet','mediaHeadline','mediaUrl','mediaThumbnail'].forEach(id=>document.getElementById(id).value='');
  toast('Media entry added ✓');
}

function renderMediaPending() {
  const el = document.getElementById('mediaPending');
  if (!state.media.length) {
    el.innerHTML = '<div style="font-family:var(--font-body);font-size:0.82rem;color:var(--muted);font-style:italic;">No media entries added yet.</div>';
    return;
  }
  el.innerHTML = state.media.map(m => `
    <div class="dash-card" style="padding:0.85rem 1rem;margin-bottom:0.5rem;border-left:3px solid var(--${m.color});">
      <div style="font-family:var(--font-head);font-size:0.72rem;color:var(--${m.color});margin-bottom:0.25rem;">${m.outlet}</div>
      <div style="font-family:var(--font-head);font-size:0.82rem;color:var(--text);margin-bottom:0.25rem;">${m.headline}</div>
      <a href="${m.url}" target="_blank" style="font-family:var(--font-body);font-size:0.7rem;color:var(--muted);word-break:break-all;">${m.url}</a>
    </div>
  `).join('');
}

// ── TIMELINE ─────────────────────────────────────────────────────────────────
function addTimelineEntry() {
  const year = document.getElementById('tlYear').value.trim();
  const tag = document.getElementById('tlTag').value.trim();
  const title = document.getElementById('tlTitle').value.trim();
  const desc = document.getElementById('tlDesc').value.trim();
  const img = document.getElementById('tlImg').value.trim();
  const imgCaption = document.getElementById('tlImgCaption').value.trim();
  if (!year || !title) { toast('Please add a year and headline.'); return; }
  state.timeline.push({year,tag,title,desc,img,imgCaption,date:new Date().toLocaleDateString()});
  saveState();
  renderTimelinePreview();
  ['tlYear','tlTag','tlTitle','tlDesc','tlImg','tlImgCaption'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('tlPreview').innerHTML = '<div style="font-family:var(--font-body);font-size:0.82rem;color:var(--muted);font-style:italic;">Fill in the form to see a preview.</div>';
  toast('Timeline entry added ✓');
}

// Live preview
['tlYear','tlTitle','tlDesc'].forEach(id => {
