      <div>
        <div style="font-family:var(--font-head);font-size:0.82rem;color:var(--text);margin-bottom:0.2rem;">${t.title}</div>
        <div class="tl-preview-text">${t.desc}</div>
      </div>
    </div>
  `).join('');
}


