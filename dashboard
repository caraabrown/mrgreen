// ── RENDER: PRIVATE MESSAGES ─────────────────────────────────────────────────
function renderPrivateMessages() {
  const msgs = state.privmsgs;
  const el = document.getElementById('privateMessages');
  document.getElementById('msgBadge').textContent = msgs.filter(m=>!m.read).length;
  el.innerHTML = msgs.map((m,i) => `
    <div class="private-msg-card ${m.read ? 'read' : 'unread'}">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.3rem;">
        <div class="msg-from">${m.from}</div>
        ${!m.read ? '<span class="tag tag-new">Unread</span>' : ''}
      </div>
      <div class="msg-context">${m.context}</div>
      <div class="msg-content">${m.message}</div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div class="msg-ts">${m.date}</div>
        ${!m.read ? `<button class="sub-btn sub-btn-approve" onclick="markMsgRead(${i})">Mark Read</button>` : ''}
      </div>
    </div>
  `).join('');
}
function markMsgRead(i) {
  state.privmsgs[i].read = true;
  saveState();
  renderPrivateMessages();
  toast('Marked as read ✓');
}

// ── RENDER: PROFILE APPROVALS ─────────────────────────────────────────────────
function renderProfiles() {
  const el = document.getElementById('profileSubmissions');
  const pending = state.profiles.filter(p=>p.status==='pending').length;
  document.getElementById('profileBadge').textContent = pending;
  el.innerHTML = state.profiles.map((p,i) => `
    <div class="submission-card ${p.status}">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.3rem;">
        <div class="sub-name">${p.name}</div>
        <span class="tag ${p.status==='approved'?'tag-answered':p.status==='declined'?'tag-new':'tag-pending'}">${p.status.charAt(0).toUpperCase()+p.status.slice(1)}</span>
      </div>
      <div class="sub-meta">${p.title} · ${p.company} · O'Dowd ${p.grad} · ${p.category}${p.mrgreen?' · ★ Your Student':''}</div>
      <div class="sub-body">${p.bio}</div>
      <div class="sub-actions">
        ${p.status!=='approved' ? `<button class="sub-btn sub-btn-approve" onclick="approveProfile(${i})">Approve & Publish</button>` : ''}
        ${p.status!=='declined' ? `<button class="sub-btn sub-btn-decline" onclick="declineProfile(${i})">Decline</button>` : ''}
        <span style="font-family:var(--font-body);font-size:0.7rem;color:var(--faint);align-self:center;margin-left:auto;">Submitted ${p.date}</span>
      </div>
    </div>
  `).join('');
}
function approveProfile(i) {
  state.profiles[i].status = 'approved';
  saveState(); renderProfiles();
  toast('Profile approved and published ✓');
}
function declineProfile(i) {
  state.profiles[i].status = 'declined';
  saveState(); renderProfiles();
  toast('Profile declined ✓');
}

// ── RENDER: LIGHT BULB STORIES ────────────────────────────────────────────────
function renderStories() {
  const pending = state.stories.filter(s=>s.status==='pending');
  const featured = state.stories.filter(s=>s.featured && s.status==='approved');
  document.getElementById('storyBadge').textContent = pending.length;

  document.getElementById('storySubmissions').innerHTML = state.stories.map((s,i) => `
    <div class="submission-card ${s.status}">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.3rem;">
        <div class="sub-name">${s.name} · ${s.location}</div>
        <span class="tag ${s.status==='approved'?'tag-answered':'tag-pending'}">${s.featured?'Featured':s.status}</span>
      </div>
      <div class="sub-body">${s.story}</div>
      <div class="sub-actions">
        ${s.status==='pending'?`<button class="sub-btn sub-btn-approve" onclick="approveStory(${i})">Approve</button>`:''}
        ${s.status==='approved'&&!s.featured?`<button class="sub-btn sub-btn-feature" onclick="featureStory(${i})">Feature on Homepage</button>`:''}
        ${s.featured?`<button class="sub-btn sub-btn-decline" onclick="unfeatureStory(${i})">Remove from Homepage</button>`:''}
        ${s.status==='pending'?`<button class="sub-btn sub-btn-decline" onclick="declineStory(${i})">Decline</button>`:''}
      </div>
    </div>
  `).join('');

  document.getElementById('featuredStories').innerHTML = featured.length
    ? featured.map(s=>`
        <div class="lb-story">
          <div class="lb-story-text">"${s.story.substring(0,180)}${s.story.length>180?'…':''}"</div>
          <div class="lb-story-attr">— ${s.name}, ${s.location}</div>
        </div>`).join('')
    : '<div style="font-family:var(--font-body);font-size:0.82rem;color:var(--faint);font-style:italic;">No featured stories yet.</div>';
}
function approveStory(i) { state.stories[i].status='approved'; saveState(); renderStories(); toast('Story approved ✓'); }
function featureStory(i) { state.stories[i].featured=true; saveState(); renderStories(); toast('Story featured on homepage ✓'); }
function unfeatureStory(i) { state.stories[i].featured=false; saveState(); renderStories(); toast('Removed from homepage ✓'); }
function declineStory(i) { state.stories[i].status='declined'; saveState(); renderStories(); toast('Story declined ✓'); }

renderQuestions();
renderBooks();
renderTimelinePreview();
renderPrivateMessages();
renderProfiles();
renderStories();
document.getElementById('qBadge').textContent = state.questions.filter(q=>!q.answer).length;
