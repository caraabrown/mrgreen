<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Mr. Green — Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;500;600;700&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#080808;--surface:#0f0f0f;--card:#161616;--border:#242424;
  --gold:#C8922A;--gold-lt:#E5B55A;--green:#078930;--green-lt:#0FAD3C;
  --crimson:#8B1F2F;--text:#F0EDE6;--muted:#7A7A7A;--faint:#2A2A2A;
  --font-disp:'Bebas Neue',sans-serif;
  --font-head:'Oswald',sans-serif;
  --font-body:'Raleway',sans-serif;
  --sidebar:260px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);display:flex;min-height:100vh;overflow-x:hidden;}

/* ── SIDEBAR ── */
.sidebar{
  width:var(--sidebar);flex-shrink:0;
  background:var(--surface);border-right:1px solid var(--faint);
  display:flex;flex-direction:column;
  position:fixed;top:0;left:0;bottom:0;z-index:50;
}
.sidebar-brand{
  padding:1.75rem 1.5rem;border-bottom:1px solid var(--faint);
}
.sidebar-brand-name{font-family:var(--font-disp);font-size:1.3rem;color:var(--gold);letter-spacing:0.08em;line-height:1;}
.sidebar-brand-sub{font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-top:0.3rem;}
.sidebar-nav{flex:1;padding:1rem 0;overflow-y:auto;}
.nav-svg{width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:0.4rem;color:var(--muted);flex-shrink:0;}
  .nav-item:hover .nav-svg,.nav-item.active .nav-svg{color:var(--text);}
  .nav-section-label{font-family:var(--font-head);font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--faint);padding:0.75rem 1.5rem 0.4rem;}
.nav-item{
  display:flex;align-items:center;gap:0.75rem;
  padding:0.7rem 1.5rem;cursor:pointer;
  font-family:var(--font-head);font-size:0.78rem;font-weight:300;
  letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);
  border-left:2px solid transparent;transition:all 0.2s;
}
.nav-item:hover{color:var(--text);background:rgba(255,255,255,0.02);}
.nav-item.active{color:var(--gold);border-left-color:var(--gold);background:rgba(200,146,42,0.05);}
.nav-item .badge{
  margin-left:auto;background:var(--crimson);color:#fff;
  font-family:var(--font-head);font-size:0.58rem;font-weight:600;
  padding:0.15rem 0.45rem;border-radius:10px;
}
.nav-icon{font-size:0.9rem;flex-shrink:0;}
.sidebar-footer{padding:1.25rem 1.5rem;border-top:1px solid var(--faint);}
.sidebar-footer-text{font-family:var(--font-body);font-size:0.72rem;color:var(--faint);line-height:1.5;}
.sidebar-footer-text a{color:var(--gold);text-decoration:none;}

/* ── MAIN ── */
.main{margin-left:var(--sidebar);flex:1;min-height:100vh;}
.topbar{
  padding:1.25rem 2.5rem;border-bottom:1px solid var(--faint);
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(8,8,8,0.9);backdrop-filter:blur(12px);
  position:sticky;top:0;z-index:40;
}
.topbar-title{font-family:var(--font-head);font-weight:700;font-size:1.1rem;color:var(--text);}
.topbar-sub{font-family:var(--font-body);font-size:0.78rem;color:var(--muted);margin-top:0.1rem;}
.save-btn{
  font-family:var(--font-head);font-size:0.72rem;font-weight:500;
  letter-spacing:0.18em;text-transform:uppercase;
  color:var(--bg);background:var(--gold);border:none;
  padding:0.6rem 1.5rem;cursor:pointer;transition:background 0.2s;
}
.save-btn:hover{background:var(--gold-lt);}
.save-btn.green{background:var(--green);}
.save-btn.green:hover{background:var(--green-lt);}

/* ── PANELS ── */
.panel{display:none;padding:2rem 2.5rem;}
.panel.active{display:block;}

/* ── CARDS ── */
.dash-card{background:var(--card);border:1px solid var(--border);padding:1.5rem;margin-bottom:1rem;}
.dash-card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;}
.dash-card-title{font-family:var(--font-head);font-weight:600;font-size:0.88rem;color:var(--text);letter-spacing:0.05em;}
.dash-card-meta{font-family:var(--font-body);font-size:0.72rem;color:var(--muted);}
.tag{
  display:inline-block;font-family:var(--font-head);font-size:0.58rem;
  letter-spacing:0.18em;text-transform:uppercase;
  padding:0.2rem 0.6rem;border-radius:2px;margin-right:0.4rem;
}
.tag-new{background:rgba(139,31,47,0.25);color:var(--crimson);border:1px solid rgba(139,31,47,0.4);}
.tag-answered{background:rgba(7,137,48,0.15);color:var(--green-lt);border:1px solid rgba(7,137,48,0.3);}
.tag-pending{background:rgba(200,146,42,0.15);color:var(--gold);border:1px solid rgba(200,146,42,0.3);}

/* ── FORM ELEMENTS ── */
.field-label{font-family:var(--font-head);font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:0.5rem;margin-top:1rem;}
.field-input{
  width:100%;padding:0.75rem 1rem;
  background:var(--surface);border:1px solid var(--border);
  color:var(--text);font-family:var(--font-body);font-size:0.88rem;font-weight:300;
  outline:none;transition:border-color 0.2s;
}
.field-input:focus{border-color:var(--gold);}
.field-input::placeholder{color:var(--faint);}
textarea.field-input{resize:vertical;min-height:100px;line-height:1.65;}
select.field-input{cursor:pointer;}

/* ── SECTION HEADERS ── */
.section-eyebrow{font-family:var(--font-head);font-weight:300;font-size:0.65rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:0.5rem;}
.section-title{font-family:var(--font-head);font-weight:700;font-size:1.4rem;color:var(--text);margin-bottom:1.5rem;line-height:1.2;}

/* ── QUESTION ITEM ── */
.q-item{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--faint);padding:1.25rem 1.5rem;margin-bottom:0.75rem;cursor:pointer;transition:border-color 0.2s;}
.q-item.unanswered{border-left-color:var(--crimson);}
.q-item.answered{border-left-color:var(--green);}
.q-item:hover{background:#1a1a1a;}
.q-text{font-family:var(--font-body);font-weight:400;font-size:0.92rem;color:var(--text);margin-bottom:0.4rem;}
.q-meta{font-family:var(--font-body);font-size:0.72rem;color:var(--muted);}

/* ── ANSWER EDITOR ── */
.answer-editor{background:var(--surface);border:1px solid var(--border);padding:1.5rem;margin-top:1rem;display:none;}
.answer-editor.open{display:block;}

/* ── MESSAGE ITEM ── */
.msg-item{background:var(--card);border:1px solid var(--border);padding:1.25rem 1.5rem;margin-bottom:0.75rem;}
.msg-sender{font-family:var(--font-head);font-weight:600;font-size:0.88rem;color:var(--text);margin-bottom:0.25rem;}
.msg-body{font-family:var(--font-body);font-weight:300;font-size:0.88rem;color:rgba(240,237,230,0.7);line-height:1.65;}
.msg-date{font-family:var(--font-body);font-size:0.72rem;color:var(--faint);margin-top:0.5rem;}
.msg-unread{border-left:3px solid var(--gold);}

/* ── BOOK LIBRARY ── */
.book-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1.5rem;}
.book-entry{
  background:var(--card);border:1px solid var(--border);
  padding:1rem;cursor:pointer;transition:border-color 0.2s;
  border-top:2px solid var(--faint);
}
.book-entry:hover{border-color:var(--gold);}
.book-entry.selected{border-top-color:var(--gold);background:rgba(200,146,42,0.05);}
.book-entry-title{font-family:var(--font-head);font-size:0.82rem;font-weight:600;color:var(--text);margin-bottom:0.2rem;}
.book-entry-author{font-family:var(--font-body);font-size:0.72rem;color:var(--muted);}

/* ── MEDIA / GALLERY UPLOAD ── */
.upload-zone{
  border:1px dashed var(--border);padding:2rem;text-align:center;
  cursor:pointer;transition:border-color 0.2s;
}
.upload-zone:hover{border-color:var(--gold);}
.upload-zone-label{font-family:var(--font-head);font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);}
.upload-icon{font-size:1.5rem;display:block;margin-bottom:0.5rem;color:var(--faint);}
.hidden-file{display:none;}

/* ── TIMELINE ENTRY ── */
.tl-entry-preview{
  display:flex;gap:1rem;align-items:start;
  background:var(--card);border:1px solid var(--border);
  border-left:3px solid var(--gold);padding:1rem 1.25rem;margin-bottom:0.75rem;
}
.tl-preview-year{font-family:var(--font-disp);font-size:1.8rem;color:var(--gold);flex-shrink:0;width:70px;}
.tl-preview-text{font-family:var(--font-body);font-size:0.82rem;color:rgba(240,237,230,0.7);line-height:1.65;}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:2rem;right:2rem;
  background:var(--green);color:#fff;
  font-family:var(--font-head);font-size:0.72rem;font-weight:500;
  letter-spacing:0.15em;text-transform:uppercase;
  padding:0.75rem 1.5rem;z-index:1000;
  opacity:0;transition:opacity 0.3s;pointer-events:none;
}
.toast.visible{opacity:1;}

/* ── STATS ROW ── */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;}
.stat-card{background:var(--card);border:1px solid var(--border);padding:1.25rem 1.5rem;}
.stat-num{font-family:var(--font-disp);font-size:2.5rem;color:var(--gold);line-height:1;}
.stat-label{font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-top:0.3rem;}

/* ── DIVIDER ── */
.divider{height:1px;background:var(--faint);margin:1.5rem 0;}

/* ── TWO COL ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;}

  /* PROFILE + STORY PANELS */
  .submission-card{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--faint);padding:1.25rem 1.5rem;margin-bottom:0.75rem;transition:border-color 0.2s;}
  .submission-card.pending{border-left-color:var(--gold);}
  .submission-card.approved{border-left-color:var(--green);}
  .submission-card.declined{border-left-color:var(--crimson);opacity:0.5;}
  .sub-name{font-family:var(--font-head);font-weight:600;font-size:0.9rem;color:var(--text);margin-bottom:0.2rem;}
  .sub-meta{font-family:var(--font-head);font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.75rem;}
  .sub-body{font-family:var(--font-body);font-size:0.82rem;color:rgba(240,237,230,0.65);line-height:1.7;margin-bottom:1rem;}
  .sub-actions{display:flex;gap:0.5rem;}
  .sub-btn{font-family:var(--font-head);font-size:0.62rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;padding:0.45rem 1rem;border:1px solid;cursor:pointer;background:none;transition:all 0.2s;}
  .sub-btn-approve{color:var(--green-lt);border-color:rgba(15,173,60,0.4);}
  .sub-btn-approve:hover{background:rgba(15,173,60,0.1);}
  .sub-btn-decline{color:var(--crimson);border-color:rgba(139,31,47,0.4);}
  .sub-btn-decline:hover{background:rgba(139,31,47,0.1);}
  .sub-btn-feature{color:var(--gold);border-color:rgba(200,146,42,0.4);}
  .sub-btn-feature:hover{background:rgba(200,146,42,0.08);}
  .lightbulb-preview{background:var(--surface);border:1px solid var(--border);padding:1.25rem;margin-top:1.5rem;}
  .lightbulb-preview-label{font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;}
  .lb-story{border-left:2px solid var(--gold);padding:0.75rem 1rem;margin-bottom:0.75rem;background:rgba(200,146,42,0.03);}
  .lb-story-text{font-family:var(--font-body);font-style:italic;font-size:0.88rem;color:rgba(240,237,230,0.7);line-height:1.7;margin-bottom:0.4rem;}
  .lb-story-attr{font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);}
  .private-msg-card{background:var(--card);border:1px solid var(--border);padding:1.25rem 1.5rem;margin-bottom:0.75rem;}
  .private-msg-card.unread{border-left:3px solid var(--gold);}
  .private-msg-card.read{border-left:3px solid var(--faint);opacity:0.7;}
  .msg-from{font-family:var(--font-head);font-weight:600;font-size:0.88rem;color:var(--text);margin-bottom:0.2rem;}
  .msg-context{font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:0.6rem;}
  .msg-content{font-family:var(--font-body);font-size:0.82rem;color:rgba(240,237,230,0.65);line-height:1.7;margin-bottom:0.75rem;}
  .msg-ts{font-family:var(--font-body);font-size:0.7rem;color:var(--faint);}

  /* DONATIONS */
  .dono-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;}
  .dono-stat{background:var(--card);border:1px solid var(--border);border-top:2px solid var(--gold);padding:1.25rem;}
  .dono-stat-num{font-family:var(--font-disp);font-size:2rem;color:var(--gold);line-height:1;}
  .dono-stat-label{font-family:var(--font-head);font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-top:0.4rem;}
  .dono-row{display:grid;grid-template-columns:auto 1fr auto auto;gap:1rem;align-items:center;padding:0.85rem 1rem;background:var(--card);border:1px solid var(--border);margin-bottom:0.4rem;}
  .dono-row-amt{font-family:var(--font-head);font-weight:600;font-size:1rem;color:var(--gold);}
  .dono-row-name{font-family:var(--font-head);font-size:0.8rem;color:var(--text);}
  .dono-row-freq{font-family:var(--font-head);font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.2rem 0.5rem;border:1px solid;}
  .dono-row-freq.monthly{color:var(--green-lt);border-color:rgba(15,173,60,0.35);}
  .dono-row-freq.once{color:var(--muted);border-color:var(--faint);}
  .dono-row-date{font-family:var(--font-body);font-size:0.72rem;color:var(--faint);}
  .dono-allocation{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-top:1.5rem;}
  .dono-alloc-card{background:var(--card);border:1px solid var(--border);padding:1rem;text-align:center;}
  .dono-alloc-pct{font-family:var(--font-disp);font-size:1.8rem;color:var(--gold);}
  .dono-alloc-label{font-family:var(--font-head);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-top:0.25rem;}

  /* PASSWORD GATE */
  .pw-gate{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;}
  .pw-gate.hidden{display:none;}
  .pw-box{width:100%;max-width:400px;padding:3rem;text-align:center;}
  .pw-brand{font-family:var(--font-disp);font-size:2.5rem;color:var(--gold);margin-bottom:0.25rem;}
  .pw-sub{font-family:var(--font-head);font-size:0.65rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);margin-bottom:3rem;}
  .pw-label{font-family:var(--font-head);font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);text-align:left;margin-bottom:0.5rem;}
  .pw-input{width:100%;background:var(--surface);border:1px solid var(--border);border-bottom:2px solid var(--gold);color:var(--text);font-family:var(--font-head);font-size:1rem;padding:0.85rem 1rem;outline:none;margin-bottom:1rem;letter-spacing:0.1em;}
  .pw-input:focus{border-color:var(--gold);}
  .pw-btn{width:100%;background:var(--gold);color:var(--bg);font-family:var(--font-head);font-size:0.78rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;border:none;padding:0.9rem;cursor:pointer;transition:background 0.2s;}
  .pw-btn:hover{background:var(--gold-lt);}
  .pw-error{font-family:var(--font-body);font-size:0.8rem;color:var(--crimson);margin-top:0.75rem;min-height:1.2rem;}
  .pw-hint{font-family:var(--font-body);font-size:0.75rem;color:var(--faint);margin-top:2rem;line-height:1.6;}
  .pw-setup-note{font-family:var(--font-body);font-size:0.82rem;color:var(--gold);margin-bottom:1.5rem;line-height:1.65;border-left:2px solid var(--gold);padding-left:0.75rem;text-align:left;}
  .pw-divider{height:1px;background:var(--faint);margin:2rem 0;}
  /* Change password inside dashboard */
  .change-pw-section{background:var(--card);border:1px solid var(--border);padding:1.5rem;margin-top:2rem;max-width:420px;}
</style>
</head>
<body>

<!-- PASSWORD GATE -->
<div class="pw-gate" id="pwGate">
  <div class="pw-box">
    <div class="pw-brand">The Whole Story</div>
    <div class="pw-sub">Mr. Green · Admin Dashboard</div>

    <!-- FIRST TIME SETUP -->
    <div id="pwSetup" style="display:none;">
      <div class="pw-setup-note">Welcome, Mr. Green. This is your first time accessing the dashboard. Please create a password to protect your admin access.</div>
      <div class="pw-label">Create Password</div>
      <input class="pw-input" id="pwNew" type="password" placeholder="Choose a password" onkeydown="if(event.key==='Enter')document.getElementById('pwConfirm').focus()"/>
      <div class="pw-label">Confirm Password</div>
      <input class="pw-input" id="pwConfirm" type="password" placeholder="Confirm your password" onkeydown="if(event.key==='Enter')setPassword()"/>
      <button class="pw-btn" onclick="setPassword()">Create Password &amp; Enter →</button>
      <div class="pw-error" id="pwSetupError"></div>
      <div class="pw-hint">Your password is stored locally on this device. If you need to reset it, contact <a href="mailto:info@getclarity.consulting" style="color:var(--gold);">Alanne International</a>.</div>
    </div>

    <!-- LOGIN -->
    <div id="pwLogin" style="display:none;">
      <div class="pw-label">Password</div>
      <input class="pw-input" id="pwEntry" type="password" placeholder="Enter your password" onkeydown="if(event.key==='Enter')checkPassword()"/>
      <button class="pw-btn" onclick="checkPassword()">Enter Dashboard →</button>
      <div class="pw-error" id="pwLoginError"></div>
      <div class="pw-hint">Forgot your password? Contact <a href="mailto:info@getclarity.consulting" style="color:var(--gold);">Alanne International</a> to reset it.</div>
    </div>
  </div>
</div>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="sidebar-brand-name">The Whole Story</div>
    <div class="sidebar-brand-sub">Mr. Green · Admin Dashboard</div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Content</div>
    <div class="nav-item active" onclick="showPanel('questions')">
      <svg class="nav-svg" viewBox="0 0 16 16"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M8 11v-1M8 5a2 2 0 0 1 0 4" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
      Questions
      <span class="badge" id="qBadge">0</span>
    </div>
    <div class="nav-item" onclick="showPanel('messages')">
      <svg class="nav-svg" viewBox="0 0 16 16"><rect x="1" y="3" width="14" height="10" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M1 5l7 5 7-5" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
      Private Messages
      <span class="badge" id="msgBadge">0</span>
    </div>
    <div class="nav-item" onclick="showPanel('profiles')">
      <svg class="nav-svg" viewBox="0 0 16 16"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M2 14c0-3 2.7-5 6-5s6 2 6 5" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
      Profile Approvals
      <span class="badge" id="profileBadge">0</span>
    </div>
    <div class="nav-item" onclick="showPanel('stories')">
      <svg class="nav-svg" viewBox="0 0 16 16"><path d="M3 2h10v12l-5-3-5 3V2z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/></svg>
      Light Bulb Stories
      <span class="badge" id="storyBadge">0</span>
